# Blender MCP Server
MCP_HOST=localhost
MCP_PORT=9876

# AI Backends — configure at least one
AI_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
CODER_MODEL=qwen2.5-coder:7b
PLANNER_MODEL=qwen3:8b

# Cloud AI (leave blank if not used)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Output / misc
BLENDER_AI_OUTPUT=~/blender_pipeline_output
MAX_RETRIES=5
THEME=dark
LOG_LEVEL=INFO
